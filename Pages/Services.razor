@page "/services"
@using CosmetologySalon.Models
@using CosmetologySalon.DTOs
@using CosmetologySalon.Services.Interfaces
@inject IService ServiceService
@inject IJSRuntime JS

<PageTitle>Управление услугами | CosmetologySalon</PageTitle>

<div class="services-page">
    <div class="page-header">
        <div>
            <h1 class="page-title text-white">Управление услугами</h1>
            <p class="page-subtitle">Просмотр, создание и управление услугами салона</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-teal" @onclick="OpenCreateModal">
                <i class="fas fa-plus"></i> Новая услуга
            </button>
            <button class="btn btn-outline-secondary" @onclick="LoadServices">
                <i class="fas fa-sync-alt"></i> Обновить
            </button>
        </div>
    </div>

    <div class="card-dark">
        <div class="card-header-dark">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="form-control search-input"
                       placeholder="Поиск по названию услуги..."
                       @bind="searchText" @bind:event="oninput" />
            </div>
        </div>
        <div class="card-body-dark">
            @if (_loading)
            {
                <div class="loading-container">
                    <div class="spinner"></div>
                    <p>Загрузка услуг...</p>
                </div>
            }
            else if (_services == null || !_displayServices.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">💅</div>
                    <h3>Нет услуг</h3>
                    <p>Нажмите кнопку "Новая услуга", чтобы создать первую услугу</p>
                </div>
            }
            else
            {
                <div class="table-container">
                    <table class="services-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название услуги</th>
                                <th>Цена</th>
                                <th>Длительность</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var service in _displayServices)
                            {
                                <tr>
                                    <td><span class="text-white">#@service.ServiceId</span></td>
                                    <td>
                                        <div class="service-info">
                                            <span class="service-icon">@GetServiceIcon(service.ServiceName)</span>
                                            <span class="service-name">@service.ServiceName</span>
                                        </div>
                                    </td>
                                    <td><span class="service-price">@service.Price.ToString("N0") ₽</span></td>
                                    <td><span class="text-white">@service.DurationMinutes мин</span></td>
                                    <td>
                                        <span class="status-badge @(service.IsActive ? "status-active" : "status-inactive")">
                                            @(service.IsActive ? "Активна" : "Неактивна")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn-edit" @onclick="() => OpenEditModal(service)" title="Редактировать">✏️</button>
                                            <button class="btn-toggle" @onclick="() => ToggleServiceStatus(service)" title="@(service.IsActive ? "Деактивировать" : "Активировать")">
                                                @(service.IsActive ? "🔴" : "🟢")
                                            </button>
                                            <button class="btn-delete" @onclick="() => DeleteService(service.ServiceId)" title="Удалить">🗑️</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Модальное окно - тёмная тема -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-container" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <div class="modal-icon">
                    <i class="fas @(isEditMode ? "fa-edit" : "fa-plus-circle")"></i>
                </div>
                <div>
                    <h3>@(isEditMode ? "Редактирование услуги" : "Новая услуга")</h3>
                    <p>@(isEditMode ? "Измените данные услуги" : "Заполните информацию об услуге")</p>
                </div>
                <button class="modal-close-btn" @onclick="CloseModal">✖</button>
            </div>
            <div class="modal-body-custom">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-alert">
                        <i class="fas fa-exclamation-circle me-2"></i> @errorMessage
                    </div>
                }

                <div class="form-group-custom">
                    <label>✨ Название услуги <span class="required">*</span></label>
                    <input type="text" class="form-control-custom @(nameError ? "is-invalid" : "")"
                           @bind="_serviceName" @bind:event="oninput"
                           placeholder="Чистка лица, Массаж, Маникюр..." />
                    @if (nameError)
                    {
                        <div class="invalid-feedback">Название услуги обязательно</div>
                    }
                </div>

                <div class="form-row-custom">
                    <div class="form-group-custom">
                        <label>💰 Цена <span class="required">*</span></label>
                        <div class="input-group-custom">
                            <input type="number" class="form-control-custom @(priceError ? "is-invalid" : "")"
                                   @bind="_price" @bind:event="oninput"
                                   placeholder="0" step="100" min="0" />
                            <span class="input-group-text">₽</span>
                        </div>
                        @if (priceError)
                        {
                            <div class="invalid-feedback">Цена должна быть больше 0</div>
                        }
                    </div>

                    <div class="form-group-custom">
                        <label>⏰ Длительность <span class="required">*</span></label>
                        <div class="input-group-custom">
                            <input type="number" class="form-control-custom @(durationError ? "is-invalid" : "")"
                                   @bind="_durationMinutes" @bind:event="oninput"
                                   placeholder="30" step="15" min="5" />
                            <span class="input-group-text">мин</span>
                        </div>
                        @if (durationError)
                        {
                            <div class="invalid-feedback">Длительность должна быть больше 0</div>
                        }
                    </div>
                </div>

                <div class="alert-info">
                    <i class="fas fa-info-circle"></i> Название услуги должно быть уникальным
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-cancel-modal" @onclick="CloseModal">Отмена</button>
                <button class="btn-save" @onclick="SaveService" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-small"></span>
                    }
                    @(isEditMode ? "Сохранить" : "Создать")
                </button>
            </div>
        </div>
    </div>
}

