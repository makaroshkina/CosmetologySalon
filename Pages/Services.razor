@code {
    private List<ServiceDto> _services = new();
    private List<ServiceDto> _displayServices = new();
    private string searchText = string.Empty;
    private bool _loading = true;
    private bool showModal = false;
    private bool isEditMode = false;
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    private string _serviceName = string.Empty;
    private int _price = 0;
    private int _durationMinutes = 30;
    private int? _editingServiceId = null;

    private bool nameError = false;
    private bool priceError = false;
    private bool durationError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadServices();
    }

    private async Task LoadServices()
    {
        _loading = true;
        try
        {
            var servicesEnumerable = await ServiceService.GetAllServicesAsync();
            _services = servicesEnumerable.ToList();
            FilterServices();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка загрузки услуг: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void FilterServices()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            _displayServices = _services.ToList();
        }
        else
        {
            _displayServices = _services
                .Where(s => s.ServiceName != null && s.ServiceName.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        StateHasChanged();
    }

    private string GetServiceIcon(string? serviceName)
    {
        if (string.IsNullOrEmpty(serviceName)) return "💅";
        if (serviceName.Contains("Лицо")) return "💆‍♀️";
        if (serviceName.Contains("Массаж")) return "💆‍♂️";
        if (serviceName.Contains("Маникюр")) return "💅";
        if (serviceName.Contains("Педикюр")) return "🦶";
        if (serviceName.Contains("Волосы")) return "💇‍♀️";
        return "✨";
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        _editingServiceId = null;
        _serviceName = string.Empty;
        _price = 0;
        _durationMinutes = 30;
        errorMessage = string.Empty;
        nameError = false;
        priceError = false;
        durationError = false;
        showModal = true;
        StateHasChanged();
    }

    private void OpenEditModal(ServiceDto service)
    {
        isEditMode = true;
        _editingServiceId = service.ServiceId;
        _serviceName = service.ServiceName ?? string.Empty;
        _price = service.Price;
        _durationMinutes = service.DurationMinutes;
        errorMessage = string.Empty;
        nameError = false;
        priceError = false;
        durationError = false;
        showModal = true;
        StateHasChanged();
    }

    private bool ValidateForm()
    {
        bool isValid = true;

        if (string.IsNullOrWhiteSpace(_serviceName))
        {
            nameError = true;
            isValid = false;
        }
        else
        {
            nameError = false;
        }

        if (_price <= 0)
        {
            priceError = true;
            isValid = false;
        }
        else
        {
            priceError = false;
        }

        if (_durationMinutes <= 0)
        {
            durationError = true;
            isValid = false;
        }
        else
        {
            durationError = false;
        }

        return isValid;
    }

    private async Task SaveService()
    {
        if (!ValidateForm())
        {
            StateHasChanged();
            return;
        }

        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            if (isEditMode && _editingServiceId.HasValue)
            {
                var updateDto = new UpdateServiceDto
                {
                    ServiceId = _editingServiceId.Value,
                    ServiceName = _serviceName.Trim(),
                    Price = _price,
                    DurationMinutes = _durationMinutes,
                    IsActive = true
                };
                await ServiceService.UpdateServiceAsync(updateDto);
                await JS.InvokeVoidAsync("alert", "Услуга успешно обновлена!");
            }
            else
            {
                var createDto = new CreateServiceDto
                {
                    ServiceName = _serviceName.Trim(),
                    Price = _price,
                    DurationMinutes = _durationMinutes
                };
                await ServiceService.AddServiceAsync(createDto);
                await JS.InvokeVoidAsync("alert", "Услуга успешно создана!");
            }

            await LoadServices();
            CloseModal();
        }
        catch (ArgumentException ex)
        {
            errorMessage = $"Ошибка валидации: {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ToggleServiceStatus(ServiceDto service)
    {
        try
        {
            if (service.IsActive)
            {
                await ServiceService.DeactivateServiceAsync(service.ServiceId);
                await JS.InvokeVoidAsync("alert", "Услуга деактивирована");
            }
            else
            {
                await ServiceService.ActivateServiceAsync(service.ServiceId);
                await JS.InvokeVoidAsync("alert", "Услуга активирована");
            }
            await LoadServices();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task DeleteService(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Вы уверены, что хотите удалить услугу? Это действие может быть невозможно отменить, если на услугу есть записи.");
        if (!confirmed) return;

        try
        {
            await ServiceService.RemoveServiceAsync(id);
            await LoadServices();
            await JS.InvokeVoidAsync("alert", "Услуга успешно удалена");
        }
        catch (InvalidOperationException ex)
        {
            await JS.InvokeVoidAsync("alert", ex.Message);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private void CloseModal()
    {
        showModal = false;
        isEditMode = false;
        _editingServiceId = null;
        errorMessage = string.Empty;
        StateHasChanged();
    }
}