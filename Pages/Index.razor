@page "/"
@using CosmetologySalon.DTOs
@using Microsoft.EntityFrameworkCore
@inject CosmetologySalon.Data.SalonAppDbContext Context
@inject NavigationManager Navigation
@inject IMaster MasterService
@inject IService ServiceService
@inject IAppointment AppointmentService

<div class="container mt-4">
    <!-- Hero секция -->
    <div class="hero-section text-center py-5 mb-5 rounded-4" style="background: linear-gradient(135deg, #0d9488 0%, #059669 100%);">
        <div class="container">
            <h1 class="display-3 fw-bold text-white mb-3">
                <i class="fas fa-spa me-3"></i>Добро пожаловать в CosmetologySalon
            </h1>
            <p class="lead text-white-50 mb-4">Наша цель - ваша красота</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <button class="btn btn-light btn-lg px-4" @onclick="GoToAppointments">
                    <i class="fas fa-calendar-alt me-2"></i>Записаться
                </button>
                <button class="btn btn-outline-light btn-lg px-4" @onclick="GoToServices">
                    <i class="fas fa-store me-2"></i>Услуги
                </button>
            </div>
        </div>
    </div>

    <!-- Статистика -->
    <div class="row text-center mb-5 g-4">
        <div class="col-md-3">
            <div class="stats-card p-4 rounded-3 shadow-sm" style="background: linear-gradient(135deg, #0d9488 0%, #059669 100%);">
                <i class="fas fa-users fa-3x text-white mb-3"></i>
                <h3 class="text-white mb-0">@_mastersCount</h3>
                <p class="text-white-50 mb-0">Профессиональных мастеров</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card p-4 rounded-3 shadow-sm" style="background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);">
                <i class="fas fa-cut fa-3x text-white mb-3"></i>
                <h3 class="text-white mb-0">@_servicesCount</h3>
                <p class="text-white-50 mb-0">Видов услуг</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card p-4 rounded-3 shadow-sm" style="background: linear-gradient(135deg, #0f766e 0%, #0d9488 100%);">
                <i class="fas fa-calendar-check fa-3x text-white mb-3"></i>
                <h3 class="text-white mb-0">@_appointmentsCount</h3>
                <p class="text-white-50 mb-0">Выполненных записей</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card p-4 rounded-3 shadow-sm" style="background: linear-gradient(135deg, #059669 0%, #047857 100%);">
                <i class="fas fa-star fa-3x text-white mb-3"></i>
                <h3 class="text-white mb-0">4.9</h3>
                <p class="text-white-50 mb-0">Рейтинг клиентов</p>
            </div>
        </div>
    </div>
        
    <!-- Наши мастера -->
    <div class="masters-section mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">
                <i class="fas fa-users text-teal me-2"></i>Наши мастера
            </h2>
            <button class="btn btn-outline-teal" @onclick="LoadMasters">
                <i class="fas fa-sync-alt me-2"></i>Обновить
            </button>
        </div>

        @if (_isLoadingMasters)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-teal" role="status">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var master in _masters.Take(4))
                {
                    <div class="col-md-4 col-lg-3">
                        <div class="master-card card shadow-sm border-0 rounded-4 text-center p-4 h-100" style="background: linear-gradient(135deg, #0d9488 0%, #059669 100%);">
                            <div class="master-avatar mx-auto mb-3">
                                <div class="avatar-circle bg-white d-flex align-items-center justify-content-center rounded-circle mx-auto" style="width: 100px; height: 100px;">
                                    <span class="display-4 fw-bold text-teal">@GetInitials(master.MasterFullName)</span>
                                </div>
                            </div>
                            <h5 class="mb-1 text-white">@master.MasterFullName</h5>
                            <p class="text-white-50 small mb-2">
                                <i class="fas fa-briefcase me-1"></i>Опытный специалист
                            </p>
                            <p class="text-warning small mb-2">
                                <i class="fas fa-star me-1"></i>
                                <i class="fas fa-star me-1"></i>
                                <i class="fas fa-star me-1"></i>
                                <i class="fas fa-star me-1"></i>
                                <i class="fas fa-star-half-alt me-1"></i>
                            </p>
                            <p class="experience-text small text-white-50">
                                <i class="fas fa-calendar-alt me-1"></i>Записей: @master.AppointmentsCount
                            </p>
                            <button class="btn btn-sm btn-outline-light mt-2 w-100" @onclick="GoToAppointments">
                                <i class="fas fa-calendar-alt me-2"></i>Записаться
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Преимущества -->
    <div class="features-section mb-5">
        <h2 class="text-center mb-5">
            <i class="fas fa-gem text-teal me-2"></i>Почему выбирают нас
        </h2>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="feature-card text-center p-4 rounded-4 shadow-sm h-100">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-medal fa-3x text-teal"></i>
                    </div>
                    <h5>Профессионализм</h5>
                    <p class="text-muted small">Опытные мастера с многолетним стажем</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-card text-center p-4 rounded-4 shadow-sm h-100">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-clock fa-3x text-teal"></i>
                    </div>
                    <h5>Удобное время</h5>
                    <p class="text-muted small">Работаем с 8:00 до 18:00 ежедневно</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-card text-center p-4 rounded-4 shadow-sm h-100">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-leaf fa-3x text-teal"></i>
                    </div>
                    <h5>Качественные материалы</h5>
                    <p class="text-muted small">Используем только премиум продукцию</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-card text-center p-4 rounded-4 shadow-sm h-100">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-hand-sparkles fa-3x text-teal"></i>
                    </div>
                    <h5>Индивидуальный подход</h5>
                    <p class="text-muted small">Учитываем все пожелания клиентов</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Отзывы -->
    <div class="reviews-section mb-5">
        <h2 class="text-center mb-5">
            <i class="fas fa-comments text-teal me-2"></i>Что говорят клиенты
        </h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="review-card p-4 rounded-4 shadow-sm h-100">
                    <div class="mb-3">
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                    </div>
                    <p class="review-text">"Отличный салон! Мастера профессионалы, обслуживание на высшем уровне. Обязательно приду еще!"</p>
                    <div class="review-author mt-3">
                        <strong>Анна Иванова</strong>
                        <div class="text-muted small">Чистка лица</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="review-card p-4 rounded-4 shadow-sm h-100">
                    <div class="mb-3">
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                    </div>
                    <p class="review-text">"Очень довольна результатом! Спасибо мастеру за профессиональный подход и отличное настроение!"</p>
                    <div class="review-author mt-3">
                        <strong>Мария Петрова</strong>
                        <div class="text-muted small">Массаж спины</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="review-card p-4 rounded-4 shadow-sm h-100">
                    <div class="mb-3">
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                        <i class="fas fa-star text-warning"></i>
                    </div>
                    <p class="review-text">"Лучший салон в городе! Всегда чисто, уютно и профессионально. Рекомендую всем!"</p>
                    <div class="review-author mt-3">
                        <strong>Екатерина Смирнова</strong>
                        <div class="text-muted small">Маникюр</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Контакты -->
    <div class="contacts-section">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="contact-card p-4 rounded-4 shadow-sm h-100">
                    <h4 class="mb-4">
                        <i class="fas fa-map-marker-alt text-teal me-2"></i>Наш адрес
                    </h4>
                    <p><i class="fas fa-location-dot me-2 text-teal"></i> г. Москва, ул. Энтузиастов, д.167</p>
                    <p><i class="fas fa-phone me-2 text-teal"></i> +7 (999) 123-45-67</p>
                    <p><i class="fas fa-envelope me-2 text-teal"></i> info@cosmetologysalon.ru</p>
                    <p><i class="fas fa-clock me-2 text-teal"></i> Пн-Вс: 8:00 - 18:00</p>
                    <div class="social-links mt-3">
                        <a href="#" class="btn btn-outline-teal btn-sm rounded-circle me-2">
                            <i class="fab fa-telegram"></i>
                        </a>
                        <a href="#" class="btn btn-outline-teal btn-sm rounded-circle me-2">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="#" class="btn btn-outline-teal btn-sm rounded-circle me-2">
                            <i class="fab fa-vk"></i>
                        </a>
                        <a href="#" class="btn btn-outline-teal btn-sm rounded-circle">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="map-card p-4 rounded-4 shadow-sm h-100">
                    <h4 class="mb-4">
                        <i class="fas fa-map text-teal me-2"></i>Как нас найти
                    </h4>
                    <div class="map-placeholder bg-light rounded-3 d-flex align-items-center justify-content-center" style="height: 250px;">
