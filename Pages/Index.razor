</div>

<!-- Footer -->
<footer class="footer mt-5 pt-4 pb-3 border-top">
    <div class="row">
        <div class="col-md-4">
            <h5><i class="fas fa-spa me-2 text-teal"></i>CosmetologySalon</h5>
            <p class="text-muted small">Салон красоты премиум класса. Забота о вашей красоте - наша главная задача.</p>
        </div>
        <div class="col-md-4">
            <h6>Быстрые ссылки</h6>
            <ul class="list-unstyled">
                <li><button class="btn btn-link text-muted small p-0 text-decoration-none" @onclick="GoToServices">Услуги</button></li>
                <li><button class="btn btn-link text-muted small p-0 text-decoration-none" @onclick="GoToAppointments">Запись онлайн</button></li>
                <li><button class="btn btn-link text-muted small p-0 text-decoration-none" @onclick="ScrollToMasters">Наши мастера</button></li>
            </ul>
        </div>
        <div class="col-md-4">
            <h6>Рабочее время</h6>
            <p class="text-muted small mb-0">Понедельник - Воскресенье</p>
            <p class="text-muted small">8:00 - 18:00</p>
        </div>
    </div>
    <div class="text-center text-muted small mt-3 pt-3 border-top">
        &copy; @DateTime.Now.Year CosmetologySalon. Все права защищены.
    </div>
</footer>

<style>
    .stats-card, .service-card, .master-card, .feature-card, .review-card, .contact-card, .map-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .stats-card:hover, .service-card:hover, .master-card:hover, .feature-card:hover, .review-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
        }

    .text-teal {
        color: #0d9488 !important;
    }

    .btn-outline-teal {
        color: #0d9488;
        border: 1px solid #0d9488;
        background: transparent;
    }

        .btn-outline-teal:hover {
            background: linear-gradient(135deg, #0d9488 0%, #059669 100%);
            color: white;
            border-color: transparent;
        }

    .avatar-circle {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        box-shadow: 0 5px 15px rgba(13, 148, 136, 0.3);
    }

    .price-tag {
        font-weight: bold;
    }

    .service-icon {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
    }

    .feature-icon {
        color: #0d9488;
    }

    .social-links .btn {
        width: 35px;
        height: 35px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .map-placeholder {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    .footer a:hover {
        color: #0d9488 !important;
    }

    .btn-light {
        background: white;
        color: #0d9488;
        border: none;
    }

        .btn-light:hover {
            background: #f8f9fa;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    .btn-outline-light:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-2px);
    }
</style>

@code {
    private List<MasterDto> _masters = new();
    private List<ServiceDto> _popularServices = new();
    private int _mastersCount = 0;
    private int _servicesCount = 0;
    private int _appointmentsCount = 0;
    private bool _isLoadingMasters = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadMasters();
        await LoadServices();
        await LoadAppointmentsCount();
    }

    private async Task LoadMasters()
    {
        try
        {
            _isLoadingMasters = true;
            _masters = await MasterService.GetAllMastersAsync();
            _mastersCount = _masters.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки мастеров: {ex.Message}");
        }
        finally
        {
            _isLoadingMasters = false;
            StateHasChanged();
        }
    }

    private async Task LoadServices()
    {
        try
        {
            var servicesEnumerable = await ServiceService.GetAllServicesAsync();
            var allServices = servicesEnumerable.ToList();
            _servicesCount = allServices.Count;           
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки услуг: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task LoadAppointmentsCount()
    {
        try
        {
            var appointments = await AppointmentService.GetAllAppointmentsAsync();
            _appointmentsCount = appointments.Count(a => a.Status == AppointmentStatus.Completed);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки записей: {ex.Message}");
        }
        StateHasChanged();
    }

    private void GoToAppointments()
    {
        Navigation.NavigateTo("/appointments");
    }

    private void GoToServices()
    {
        Navigation.NavigateTo("/services");
    }

    private void ScrollToMasters()
    {
        Navigation.NavigateTo("/masters");
    }

    private string GetInitials(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "M";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2 && parts[0].Length > 0 && parts[1].Length > 0)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        if (parts.Length >= 1 && parts[0].Length > 0)
            return parts[0][0].ToString().ToUpper();
        return "M";
    }
}