        gap: 8px;
    }

    .btn-cancel-modal {
        padding: 10px 24px;
        border-radius: 10px;
        border: 1px solid rgba(20, 184, 166, 0.3);
        background: #1e293b;
        color: #e2e8f0;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 14px;
        font-weight: 500;
    }

        .btn-cancel-modal:hover {
            background: #334155;
            border-color: #14b8a6;
        }

    .btn-save {
        padding: 10px 28px;
        border-radius: 10px;
        border: none;
        background: linear-gradient(135deg, #0d9488, #059669);
        color: white;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 14px;
        font-weight: 500;
    }

        .btn-save:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(13, 148, 136, 0.4);
        }

        .btn-save:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    @@media (max-width: 768px) {
        .masters-page

    {
        padding: 12px;
    }

    .page-header {
        flex-direction: column;
        align-items: stretch;
    }

    .header-actions {
        justify-content: stretch;
    }

        .header-actions button {
            flex: 1;
            text-align: center;
        }

    .search-box {
        max-width: 100%;
    }

    .masters-table {
        font-size: 12px;
    }

    .action-buttons {
        flex-direction: column;
    }

    .modal-container {
        width: 95%;
        margin: 16px;
    }

    }
</style>

@code {
    private List<MasterDto> _masters = new();
    private List<MasterDto> _displayMasters = new();
    private string searchText = string.Empty;

    private bool showModal = false;
    private bool isEditMode = false;
    private int? editingMasterId = null;
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    private string _masterFullName = string.Empty;
    private string _masterPhone = string.Empty;
    private string? _masterEmail = string.Empty;

    private bool nameError = false;
    private bool phoneError = false;
    private bool emailError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadMasters();
    }

    private async Task LoadMasters()
    {
        try
        {
            _masters = await MasterService.GetAllMastersAsync();

            foreach (var master in _masters)
            {
                var appointmentsCount = await Context.Appointments
                    .CountAsync(a => a.MasterId == master.MasterId);
                master.AppointmentsCount = appointmentsCount;
            }

            FilterMasters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка загрузки мастеров: {ex.Message}";
        }
        StateHasChanged();
    }

    private void FilterMasters()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            _displayMasters = _masters.ToList();
        }
        else
        {
            _displayMasters = _masters
                .Where(m => (m.MasterFullName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                           (m.MasterPhone?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                           (m.MasterEmail != null && m.MasterEmail.Contains(searchText, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }
        StateHasChanged();
    }

    private void ShowCreateModal()
    {
        isEditMode = false;
        editingMasterId = null;
        ResetForm();
        showModal = true;
        StateHasChanged();
    }

    private void ShowEditModal(MasterDto master)
    {
        isEditMode = true;
        editingMasterId = master.MasterId;
        _masterFullName = master.MasterFullName ?? string.Empty;
        _masterPhone = master.MasterPhone;
        _masterEmail = master.MasterEmail;
        errorMessage = string.Empty;
        nameError = false;
        phoneError = false;
        emailError = false;
        showModal = true;
        StateHasChanged();
    }

    private void ResetForm()
    {
        _masterFullName = string.Empty;
        _masterPhone = string.Empty;
        _masterEmail = string.Empty;
        errorMessage = string.Empty;
        nameError = false;
        phoneError = false;
        emailError = false;
    }

    private bool ValidateForm()
    {
        bool isValid = true;

        if (string.IsNullOrWhiteSpace(_masterFullName))
        {
            nameError = true;
            isValid = false;
        }
        else
        {
            nameError = false;
        }

        if (string.IsNullOrWhiteSpace(_masterPhone))
        {
            phoneError = true;
            isValid = false;
        }
        else
        {
            phoneError = false;
        }

        if (!string.IsNullOrEmpty(_masterEmail) && !_masterEmail.Contains("@"))
        {
            emailError = true;
            isValid = false;
        }
        else
        {
            emailError = false;
        }

        return isValid;
    }

    private async Task SaveMaster()
    {
        if (!ValidateForm())
        {
            StateHasChanged();
            return;
        }

        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            if (isEditMode && editingMasterId.HasValue)
            {
                var updateMasterDto = new UpdateMasterDto
                {
                    MasterId = editingMasterId.Value,
                    MasterFullName = _masterFullName.Trim(),
                    MasterPhone = _masterPhone.Trim(),
                    MasterEmail = string.IsNullOrWhiteSpace(_masterEmail) ? null : _masterEmail.Trim(),
                    IsActive = true,
                    AppointmentsCount = 0
                };

                await MasterService.UpdateMasterAsync(updateMasterDto);
                await JS.InvokeVoidAsync("alert", "Мастер успешно обновлен!");
            }
            else
            {
                var createMasterDto = new CreateMasterDto
                {
                    MasterFullName = _masterFullName.Trim(),
                    MasterPhone = _masterPhone.Trim(),
                    MasterEmail = string.IsNullOrWhiteSpace(_masterEmail) ? null : _masterEmail.Trim()
                };

                await MasterService.AddMasterAsync(createMasterDto);
                await JS.InvokeVoidAsync("alert", "Мастер успешно добавлен!");
            }

            await LoadMasters();
            CloseModal();
        }
        catch (ArgumentException ex)
        {
            errorMessage = $"Ошибка валидации: {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (DbUpdateException ex)
        {
            var innerMessage = ex.InnerException?.Message ?? ex.Message;
            if (innerMessage.Contains("IX_Masters_MasterPhone"))
                errorMessage = "Мастер с таким номером телефона уже существует";
            else if (innerMessage.Contains("IX_Masters_MasterEmail"))
                errorMessage = "Мастер с таким email уже существует";
            else
                errorMessage = $"Ошибка базы данных: {innerMessage}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Неизвестная ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ToggleMasterStatus(MasterDto master)
    {
        try
        {
            var existingMaster = await Context.Masters.FindAsync(master.MasterId);
            if (existingMaster != null)
            {
                existingMaster.IsActive = !master.IsActive;
                await Context.SaveChangesAsync();

                var action = existingMaster.IsActive ? "активирован" : "деактивирован";
                await LoadMasters();
                await JS.InvokeVoidAsync("alert", $"Мастер {action}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task DeleteMaster(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Вы уверены, что хотите удалить мастера? Это также удалит все его записи."))
            return;

        try
        {
            await MasterService.RemoveMasterAsync(id);
            await LoadMasters();
            await JS.InvokeVoidAsync("alert", "Мастер успешно удален");
        }
        catch (InvalidOperationException ex)
        {
            await JS.InvokeVoidAsync("alert", ex.Message);
        }
        catch (DbUpdateException ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка удаления: {ex.InnerException?.Message ?? ex.Message}");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private void CloseModal()
    {
        showModal = false;
        isEditMode = false;
        editingMasterId = null;
        ResetForm();
        StateHasChanged();
    }
}