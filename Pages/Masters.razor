        }

    .input-group-custom {
        display: flex;
        align-items: stretch;
    }

        .input-group-custom .form-control-custom {
            flex: 1;
            border-radius: 10px 0 0 10px;
        }

    .input-group-text {
        background: #1e293b;
        border: 1px solid rgba(20, 184, 166, 0.25);
        border-left: none;
        padding: 10px 14px;
        border-radius: 0 10px 10px 0;
        font-size: 14px;
        color: #14b8a6;
    }

    .invalid-feedback {
        color: #f87171;
        font-size: 12px;
        margin-top: 6px;
        display: block;
    }

    .form-text {
        font-size: 11px;
