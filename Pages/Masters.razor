@page "/masters"
@using CosmetologySalon.Models
@using CosmetologySalon.DTOs
@using CosmetologySalon.Services.Interfaces
@using Microsoft.EntityFrameworkCore
@inject CosmetologySalon.Data.SalonAppDbContext Context
@inject IMaster MasterService
@inject IJSRuntime JS
@namespace CosmetologySalon.Pages

<PageTitle>Управление мастерами | Косметология Салон</PageTitle>

<div class="masters-page">
    <div class="page-header">
        <div>
            <h1 class="page-title text-white">Управление мастерами</h1>
            <p class="page-subtitle">Добавление, редактирование и управление мастерами салона</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-teal" @onclick="ShowCreateModal">
                <i class="fas fa-plus"></i> Новый мастер
            </button>
            <button class="btn btn-outline-secondary" @onclick="LoadMasters">
                <i class="fas fa-sync-alt"></i> Обновить
            </button>
        </div>
    </div>

    <div class="card-dark">
        <div class="card-header-dark">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="form-control search-input"
                       placeholder="Поиск по имени, телефону или email..."
                       @bind="searchText" @bind:event="oninput" />
            </div>
        </div>
        <div class="card-body-dark">
            @if (_masters == null)
            {
                <div class="loading-container">
                    <div class="spinner"></div>
                    <p>Загрузка мастеров...</p>
                </div>
            }
            else if (!_displayMasters.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">👩‍🎨</div>
                    <h3>Нет мастеров</h3>
                    <p>Нажмите кнопку "Новый мастер", чтобы добавить первого мастера</p>
                </div>
            }
            else
            {
                <div class="table-container">
                    <table class="masters-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>ФИО</th>
                                <th>Телефон</th>
                                <th>Email</th>
                                <th>Статус</th>
                                <th>Записей</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var master in _displayMasters)
                            {
                                <tr>
                                    <td>#@master.MasterId</td>
                                    <td>
                                        <div class="master-info">
                                            <div class="master-avatar">
                                                <i class="fas fa-user-md"></i>
                                            </div>
                                            <div class="master-details">
                                                <span class="master-name">@master.MasterFullName</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="tel:@master.MasterPhone" class="contact-link">
                                            <i class="fas fa-phone-alt me-1"></i> @master.MasterPhone
                                        </a>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(master.MasterEmail))
                                        {
                                            <a href="mailto:@master.MasterEmail" class="contact-link">
                                                <i class="fas fa-envelope me-1"></i> @master.MasterEmail
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (master.IsActive)
                                        {
                                            <span class="status-badge status-active">
                                                <i class="fas fa-circle me-1" style="font-size: 8px;"></i> Активен
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive">
                                                <i class="fas fa-circle me-1" style="font-size: 8px;"></i> Неактивен
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <span class="appointment-count">
                                            @(master.AppointmentsCount ?? 0)
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn-edit" @onclick="() => ShowEditModal(master)" title="Редактировать">✏️</button>
                                            <button class="btn-toggle" @onclick="() => ToggleMasterStatus(master)" title="@(master.IsActive ? "Деактивировать" : "Активировать")">
                                                @(master.IsActive ? "🔴" : "🟢")
                                            </button>
                                            <button class="btn-delete" @onclick="() => DeleteMaster(master.MasterId)" title="Удалить">🗑️</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Модальное окно - тёмная тема -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-container" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <div class="modal-icon">
                    <i class="fas @(isEditMode ? "fa-user-md" : "fa-user-plus")"></i>
                </div>
                <div>
                    <h3>@(isEditMode ? "Редактирование мастера" : "Новый мастер")</h3>
                    <p>@(isEditMode ? "Измените данные мастера" : "Заполните информацию о мастере")</p>
                </div>
                <button class="modal-close-btn" @onclick="CloseModal">✖</button>
            </div>
            <div class="modal-body-custom">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-alert">
                        <i class="fas fa-exclamation-circle me-2"></i> @errorMessage
                    </div>
                }

                <div class="form-group-custom">
                    <label>👤 ФИО мастера <span class="required">*</span></label>
                    <input type="text" class="form-control-custom @(nameError ? "is-invalid" : "")"
                           @bind="_masterFullName" @bind:event="oninput"
                           placeholder="Петрова Екатерина Дмитриевна" />
                    @if (nameError)
                    {
                        <div class="invalid-feedback">ФИО обязательно для заполнения</div>
                    }
                </div>

                <div class="form-group-custom">
                    <label>📞 Телефон <span class="required">*</span></label>
                    <div class="input-group-custom">
                        <span class="input-group-text">+7</span>
                        <input type="tel" class="form-control-custom @(phoneError ? "is-invalid" : "")"
                               @bind="_masterPhone" @bind:event="oninput"
                               placeholder="9991234567" maxlength="10" />
                    </div>
                    @if (phoneError)
                    {
                        <div class="invalid-feedback">Телефон обязателен (10 цифр после +7)</div>
                    }
                    <small class="form-text text-muted">Формат: 9991234567 (без +7)</small>
                </div>

                <div class="form-group-custom">
                    <label>📧 Email</label>
                    <input type="email" class="form-control-custom @(emailError ? "is-invalid" : "")"
                           @bind="_masterEmail" @bind:event="oninput"
                           placeholder="master@example.com" />
                    @if (emailError)
                    {
                        <div class="invalid-feedback">Введите корректный email</div>
                    }
                    <small class="form-text text-muted">Необязательно, но рекомендуется</small>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-cancel-modal" @onclick="CloseModal">Отмена</button>
                <button class="btn-save" @onclick="SaveMaster" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-small"></span>
                    }
                    @(isEditMode ? "Сохранить изменения" : "Добавить мастера")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .masters-page {
        padding: 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
