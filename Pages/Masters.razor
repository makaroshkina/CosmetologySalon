        color: #3b82f6;
    }

        .btn-edit:hover {
            background: #3b82f6;
            color: white;
        }

    .btn-toggle {
        background: #fef3c7;
        color: #d97706;
    }

        .btn-toggle:hover {
            background: #d97706;
            color: white;
        }

    .btn-delete {
        background: #fee2e2;
        color: #ef4444;
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
        }

    /* Loading & Empty States */
    .loading-container {
        text-align: center;
        padding: 60px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #e2e8f0;
        border-top-color: #0d9488;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
