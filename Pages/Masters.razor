    }

    .text-muted {
        color: #64748b;
    }

    /* ===== МОДАЛЬНОЕ ОКНО - ТЁМНАЯ ТЕМА ===== */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.75);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-container {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        border: 1px solid rgba(20, 184, 166, 0.3);
