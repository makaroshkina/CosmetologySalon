@code {
    private List<AppointmentDto> _appointments = new();
    private List<AppointmentDto> _displayAppointments = new();
    private List<ClientDto> _clients = new();
    private List<MasterDto> _masters = new();
    private List<ServiceDto> _services = new();
    private string searchText = string.Empty;
    private bool _loading = true;
    private bool showModal = false;
    private bool isEditMode = false;
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    private DateTime? _selectedDateTime = DateTime.UtcNow;
    private int _selectedClientId = 0;
    private int _selectedMasterId = 0;
    private int _selectedServiceId = 0;
    private AppointmentStatus _selectedStatus = AppointmentStatus.Scheduled;
    private int? _editingAppointmentId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _clients = await ClientService.GetAllClientsAsync();
            _masters = await MasterService.GetAllMastersAsync();
            var servicesEnumerable = await ServiceService.GetAllServicesAsync();
            _services = servicesEnumerable.ToList();
            _appointments = await AppointmentService.GetAllAppointmentsAsync();
            _appointments = _appointments.OrderByDescending(a => a.AppointmentDateTime).ToList();
            FilterAppointments();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка загрузки данных: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void FilterAppointments()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            _displayAppointments = _appointments.ToList();
        }
        else
        {
            _displayAppointments = _appointments
                .Where(a => GetClientName(a.ClientId).Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                           GetMasterName(a.MasterId).Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                           GetServiceName(a.ServiceId).Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        StateHasChanged();
    }

    private string GetClientName(int clientId)
    {
        var client = _clients.FirstOrDefault(c => c.ClientId == clientId);
        return client?.ClientFullName ?? "Не указан";
    }

    private string GetMasterName(int masterId)
    {
        var master = _masters.FirstOrDefault(m => m.MasterId == masterId);
        return master?.MasterFullName ?? "Не указан";
    }

    private string GetServiceName(int serviceId)
    {
        var service = _services.FirstOrDefault(s => s.ServiceId == serviceId);
        return service?.ServiceName ?? "Не указана";
    }

    private string GetStatusClass(AppointmentStatus status)
    {
        return status switch
        {
            AppointmentStatus.Scheduled => "status-scheduled",
            AppointmentStatus.Confirmed => "status-confirmed",
            AppointmentStatus.Rescheduled => "status-rescheduled",
            AppointmentStatus.Completed => "status-completed",
            AppointmentStatus.Cancelled => "status-cancelled",
            _ => "status-scheduled"
        };
    }

    private string GetStatusText(AppointmentStatus status)
    {
        return status switch
        {
            AppointmentStatus.Scheduled => "Запланирована",
            AppointmentStatus.Confirmed => "Подтверждена",
            AppointmentStatus.Rescheduled => "Перенесена",
            AppointmentStatus.Completed => "Завершена",
            AppointmentStatus.Cancelled => "Отменена",
            _ => status.ToString()
        };
    }

    private void UpdateDate(string? dateValue)
    {
        if (!string.IsNullOrEmpty(dateValue) && DateTime.TryParse(dateValue, out var date))
        {
            if (_selectedDateTime.HasValue)
            {
                _selectedDateTime = new DateTime(date.Year, date.Month, date.Day,
                    _selectedDateTime.Value.Hour, _selectedDateTime.Value.Minute, 0, DateTimeKind.Utc);
            }
            else
            {
                _selectedDateTime = DateTime.SpecifyKind(date, DateTimeKind.Utc);
            }
            StateHasChanged();
        }
    }

    private void UpdateTime(string? timeValue)
    {
        if (!string.IsNullOrEmpty(timeValue) && TimeSpan.TryParse(timeValue, out var time))
        {
            if (_selectedDateTime.HasValue)
            {
                _selectedDateTime = new DateTime(_selectedDateTime.Value.Year, _selectedDateTime.Value.Month, _selectedDateTime.Value.Day,
                    time.Hours, time.Minutes, 0, DateTimeKind.Utc);
            }
            else
            {
                _selectedDateTime = DateTime.SpecifyKind(DateTime.Today.Add(time), DateTimeKind.Utc);
            }
            StateHasChanged();
        }
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        _editingAppointmentId = null;
        _selectedClientId = 0;
        _selectedMasterId = 0;
        _selectedServiceId = 0;
        _selectedDateTime = DateTime.UtcNow;
        errorMessage = string.Empty;
        showModal = true;
        StateHasChanged();
    }

    private void OpenEditModal(AppointmentDto appointment)
    {
        isEditMode = true;
        _editingAppointmentId = appointment.Id;
        _selectedClientId = appointment.ClientId;
        _selectedMasterId = appointment.MasterId;
        _selectedServiceId = appointment.ServiceId;
        _selectedDateTime = appointment.AppointmentDateTime;
        _selectedStatus = appointment.Status;
        errorMessage = string.Empty;
        showModal = true;
        StateHasChanged();
    }

    private async Task SaveAppointment()
    {
        if (_selectedClientId == 0)
        {
            errorMessage = "Выберите клиента";
            StateHasChanged();
            return;
        }
        if (_selectedMasterId == 0)
        {
            errorMessage = "Выберите мастера";
            StateHasChanged();
            return;
        }
        if (_selectedServiceId == 0)
        {
            errorMessage = "Выберите услугу";
            StateHasChanged();
            return;
        }
        if (!_selectedDateTime.HasValue)
        {
            errorMessage = "Укажите дату и время";
            StateHasChanged();
            return;
        }

        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var appointmentDateTime = DateTime.SpecifyKind(_selectedDateTime.Value, DateTimeKind.Utc);

            if (isEditMode && _editingAppointmentId.HasValue)
            {
                await AppointmentService.RescheduleAppointmentAsync(_editingAppointmentId.Value, appointmentDateTime);
                await JS.InvokeVoidAsync("alert", "Запись успешно обновлена!");
            }
            else
            {
                var createDto = new CreateAppointmentDto
                {
                    ClientId = _selectedClientId,
                    MasterId = _selectedMasterId,
                    ServiceId = _selectedServiceId,
                    AppointmentDateTime = appointmentDateTime
                };
                await AppointmentService.CreateAppointmentAsync(createDto);
                await JS.InvokeVoidAsync("alert", "Запись успешно создана!");
            }

            await LoadData();
            CloseModal();
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmAppointment(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Подтвердить эту запись?");
        if (!confirmed) return;

        try
        {
            var result = await AppointmentService.ConfirmAppointmentAsync(id);
            if (result)
            {
                await JS.InvokeVoidAsync("alert", "Запись подтверждена");
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task CancelAppointment(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Вы уверены, что хотите отменить эту запись?");
        if (!confirmed) return;

        try
        {
            var appointment = await AppointmentService.GetAppointmentByIdAsync(id);
            if (appointment != null)
            {
                await AppointmentService.RescheduleAppointmentAsync(id, appointment.AppointmentDateTime);
                await JS.InvokeVoidAsync("alert", "Запись отменена");
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private void CloseModal()
    {
        showModal = false;
        isEditMode = false;
        _editingAppointmentId = null;
        errorMessage = string.Empty;
        StateHasChanged();
    }
}