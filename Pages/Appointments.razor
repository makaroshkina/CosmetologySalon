@page "/appointments"
@using CosmetologySalon.Models
@using CosmetologySalon.DTOs
@using CosmetologySalon.Services.Interfaces
@inject IAppointment AppointmentService
@inject IClient ClientService
@inject IMaster MasterService
@inject IService ServiceService
@inject IJSRuntime JS

<PageTitle>Управление записями | CosmetologySalon</PageTitle>

<div class="appointments-page">
    <div class="page-header">
        <div>
            <h1 class="page-title text-white">Управление записями</h1>
            <p class="page-subtitle">Просмотр, создание и управление записями клиентов</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-teal" @onclick="OpenCreateModal">
                <i class="fas fa-plus"></i> Новая запись
            </button>
            <button class="btn btn-outline-secondary" @onclick="LoadData">
                <i class="fas fa-sync-alt"></i> Обновить
            </button>
        </div>
    </div>

    <div class="card-dark">
        <div class="card-header-dark">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="form-control search-input"
                       placeholder="Поиск по клиенту, мастеру или услуге..."
                       @bind="searchText" @bind:event="oninput" />
            </div>
        </div>
        <div class="card-body-dark">
            @if (_loading)
            {
                <div class="loading-container">
                    <div class="spinner"></div>
                    <p>Загрузка записей...</p>
                </div>
            }
            else if (_appointments == null || !_displayAppointments.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📅</div>
                    <h3>Нет записей</h3>
                    <p>Нажмите кнопку "Новая запись", чтобы создать первую запись</p>
                </div>
            }
            else
            {
                <div class="table-container">
                    <table class="appointments-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Дата и время</th>
                                <th>Клиент</th>
                                <th>Мастер</th>
                                <th>Услуга</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appointment in _displayAppointments)
                            {
                                <tr>
                                    <td>#@appointment.Id</td>
                                    <td>@appointment.AppointmentDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@GetClientName(appointment.ClientId)</td>
                                    <td>@GetMasterName(appointment.MasterId)</td>
                                    <td>@GetServiceName(appointment.ServiceId)</td>
                                    <td>
                                        <span class="status-badge @GetStatusClass(appointment.Status)">
                                            @GetStatusText(appointment.Status)
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn-edit" @onclick="() => OpenEditModal(appointment)" title="Редактировать">✏️</button>
                                            <button class="btn-confirm" @onclick="() => ConfirmAppointment(appointment.Id)" title="Подтвердить">✅</button>
                                            <button class="btn-cancel" @onclick="() => CancelAppointment(appointment.Id)" title="Отменить">❌</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Модальное окно - тёмная тема -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-container" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <div class="modal-icon">
                    <i class="fas @(isEditMode ? "fa-edit" : "fa-plus-circle")"></i>
                </div>
                <div>
                    <h3>@(isEditMode ? "Редактирование записи" : "Новая запись")</h3>
                    <p>@(isEditMode ? "Измените данные записи" : "Заполните информацию о записи")</p>
                </div>
                <button class="modal-close-btn" @onclick="CloseModal">✖</button>
            </div>
            <div class="modal-body-custom">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-alert">
                        <i class="fas fa-exclamation-circle me-2"></i> @errorMessage
                    </div>
                }

                <div class="form-group-custom">
                    <label>👤 Клиент <span class="required">*</span></label>
                    <select class="form-control-custom" @bind="_selectedClientId">
                        <option value="0">-- Выберите клиента --</option>
                        @foreach (var client in _clients)
                        {
                            <option value="@client.ClientId">@client.ClientFullName (@client.ClientPhone)</option>
                        }
                    </select>
                </div>

                <div class="form-group-custom">
                    <label>💇 Мастер <span class="required">*</span></label>
                    <select class="form-control-custom" @bind="_selectedMasterId">
                        <option value="0">-- Выберите мастера --</option>
                        @foreach (var master in _masters)
                        {
                            <option value="@master.MasterId">@master.MasterFullName (@master.MasterPhone)</option>
                        }
                    </select>
                </div>

                <div class="form-group-custom">
                    <label>✨ Услуга <span class="required">*</span></label>
                    <select class="form-control-custom" @bind="_selectedServiceId">
                        <option value="0">-- Выберите услугу --</option>
                        @foreach (var service in _services)
                        {
                            <option value="@service.ServiceId">@service.ServiceName - @service.Price ₽ (@service.DurationMinutes мин)</option>
                        }
                    </select>
                </div>

                <div class="form-row-custom">
                    <div class="form-group-custom">
                        <label>📅 Дата <span class="required">*</span></label>
                        <input type="date" class="form-control-custom"
                               value="@(_selectedDateTime?.ToString("yyyy-MM-dd"))"
                               @onchange="(ChangeEventArgs e) => UpdateDate(e.Value?.ToString())" />
                    </div>
                    <div class="form-group-custom">
                        <label>⏰ Время <span class="required">*</span></label>
                        <input type="time" class="form-control-custom"
                               value="@(_selectedDateTime?.ToString(@"hh\:mm"))"
                               @onchange="(ChangeEventArgs e) => UpdateTime(e.Value?.ToString())" />
                    </div>
                </div>

                @if (isEditMode)
                {
                    <div class="form-group-custom">
                        <label>📌 Статус</label>
                        <select class="form-control-custom" @bind="_selectedStatus">
                            <option value="@AppointmentStatus.Scheduled">Запланирована</option>
                            <option value="@AppointmentStatus.Confirmed">Подтверждена</option>
                            <option value="@AppointmentStatus.Rescheduled">Перенесена</option>
                            <option value="@AppointmentStatus.Completed">Завершена</option>
                            <option value="@AppointmentStatus.Cancelled">Отменена</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn-cancel-modal" @onclick="CloseModal">Отмена</button>
                <button class="btn-save" @onclick="SaveAppointment" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-small"></span>
                    }
                    @(isEditMode ? "Сохранить" : "Создать")
                </button>
            </div>
        </div>
    </div>
}

