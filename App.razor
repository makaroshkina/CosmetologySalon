@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor
<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(CosmetologySalon.Shared.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Не найдено</PageTitle>
        <LayoutView Layout="@typeof(CosmetologySalon.Shared.MainLayout)">
            <div class="container text-center mt-5">
                <h1 class="text-white mb-3">Страница не найдена</h1>
                <p class="text-white-50">Запрашиваемая страница не существует.</p>
                <a href="/" class="btn btn-teal mt-3">
                    <i class="fas fa-home me-2"></i>На главную
                </a>
            </div>
        </LayoutView>
    </NotFound>
</Router>