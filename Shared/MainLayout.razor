@inherits LayoutComponentBase
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using CosmetologySalon.Models
@using CosmetologySalon.DTOs
@using CosmetologySalon.Services.Interfaces
@inject NavigationManager Navigation
@inject CosmetologySalon.Data.SalonAppDbContext Context
@inject IJSRuntime JS

<div class="page" @onclick="CloseDropdownOnOutside">
    <!-- Боковое меню -->
    <nav class="nav-menu">
        <div class="nav-header">
            <div class="logo" @onclick='() => Navigation.NavigateTo("/")' style="cursor: pointer;">
                <i class="fas fa-spa logo-icon"></i>
                <span class="logo-text">CosmetologySalon</span>
            </div>
        </div>
        <div class="nav-links">
            <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span>
                <span>Главная</span>
            </NavLink>

            <div class="nav-group">
                <div class="nav-group-title">Управление</div>
                <NavLink href="/clients" class="nav-link">
                    <span class="nav-icon">👥</span>
                    <span>Клиенты</span>
                </NavLink>
                <NavLink href="/masters" class="nav-link">
                    <span class="nav-icon">💇‍♀️</span>
                    <span>Мастера</span>
                </NavLink>
                <NavLink href="/services" class="nav-link">
                    <span class="nav-icon">💅</span>
                    <span>Услуги</span>
                </NavLink>
            </div>

            <div class="nav-group">
                <div class="nav-group-title">Операции</div>
                <NavLink href="/appointments" class="nav-link">
                    <span class="nav-icon">📅</span>
                    <span>Записи</span>
                </NavLink>
            </div>
        </div>
    </nav>

    <!-- Основной контент -->
    <main class="main-content">
        <!-- Верхняя панель -->
        <div class="top-bar">
            <div class="top-bar-content">                
                <div class="auth-buttons">
                    @if (_currentClientId == 0)
                    {
                        <button class="btn btn-outline-teal btn-sm" @onclick="ShowLoginModal">
                            <i class="fas fa-sign-in-alt me-1"></i>Войти
                        </button>
                        <button class="btn btn-teal btn-sm" @onclick="ShowRegisterModal">
                            <i class="fas fa-user-plus me-1"></i>Регистрация
                        </button>
                    }
                    else
                    {
                        <div class="dropdown-container">
                            <button class="user-menu-btn" @onclick="ToggleDropdown" @onclick:stopPropagation>
                                <i class="fas fa-user-circle me-1"></i>@_currentClientName
                                <span class="dropdown-arrow">▼</span>
                            </button>

                            @if (showDropdown)
                            {
                                <div class="dropdown-menu-custom" @onclick:stopPropagation>
                                    <div class="dropdown-header">
                                        <i class="fas fa-id-card me-1"></i>
                                        <span class="badge-client">Клиент</span>
                                    </div>
                                    <div class="dropdown-divider"></div>
                                    <button class="dropdown-item" @onclick="GoToMyAppointments">
                                        <i class="fas fa-calendar-alt me-2 text-teal"></i>
                                        <span>Мои записи</span>
                                    </button>
                                    <div class="dropdown-divider"></div>
                                    <button class="dropdown-item text-danger" @onclick="Logout">
                                        <i class="fas fa-sign-out-alt me-2"></i>Выйти
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Контент страницы -->
        <article class="content px-4">
            @Body
        </article>
    </main>

    <!-- Модальное окно входа -->
    @if (showLoginModal)
    {
        <div class="modal-backdrop" @onclick="CloseLoginModal"></div>
        <div class="modal-custom modal-login" @onclick:stopPropagation>
            <div class="modal-header-dark">
                <h5 class="modal-title text-white">
                    <i class="fas fa-sign-in-alt text-teal me-2"></i>Вход в аккаунт
                </h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseLoginModal"></button>
            </div>
            <div class="modal-body-dark">
                @if (!string.IsNullOrEmpty(loginErrorMessage))
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle me-2"></i>@loginErrorMessage
                    </div>
                }

                <div class="form-group">
                    <label class="form-label text-white">Телефон <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-dark">+7</span>
                        <input type="tel" class="form-control form-control-dark @(loginPhoneError ? "is-invalid" : "")"
                               @bind="_loginPhone" @bind:event="oninput" placeholder="9991234567" maxlength="10" />
                    </div>
                    @if (loginPhoneError)
                    {
                        <div class="invalid-feedback">Введите номер телефона</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label text-white">Пароль <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="@(showLoginPassword ? "text" : "password")"
                               class="form-control form-control-dark @(loginPasswordError ? "is-invalid" : "")"
                               @bind="_loginPassword" @bind:event="oninput" placeholder="Введите пароль" />
                        <button class="btn btn-outline-teal" type="button" @onclick="() => showLoginPassword = !showLoginPassword">
                            <i class="fas @(showLoginPassword ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                    @if (loginPasswordError)
                    {
                        <div class="invalid-feedback">Введите пароль</div>
                    }
                </div>

                <button class="btn btn-teal w-100 py-2" @onclick="Login" disabled="@isLoggingIn">
                    @if (isLoggingIn)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="fas fa-sign-in-alt me-2"></i>Войти
                </button>

                <div class="text-center mt-3">
                    <p class="text-white-50 mb-0">
                        Нет аккаунта?
                        <button class="btn btn-link p-0 text-teal" @onclick="SwitchToRegister">
                            Зарегистрироваться
                        </button>
                    </p>
                </div>
            </div>
        </div>
    }

    <!-- Модальное окно регистрации -->
    @if (showRegisterModal)
    {
        <div class="modal-backdrop" @onclick="CloseRegisterModal"></div>
        <div class="modal-custom modal-login" @onclick:stopPropagation>
            <div class="modal-header-dark">
                <h5 class="modal-title text-white">
                    <i class="fas fa-user-plus text-teal me-2"></i>Регистрация
                </h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseRegisterModal"></button>
            </div>
            <div class="modal-body-dark">
                @if (!string.IsNullOrEmpty(registerErrorMessage))
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle me-2"></i>@registerErrorMessage
                    </div>
                }

                <div class="form-group">
                    <label class="form-label text-white">ФИО <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-dark @(regNameError ? "is-invalid" : "")"
                           @bind="_regFullName" @bind:event="oninput" placeholder="Иванов Иван Иванович" />
                    @if (regNameError)
                    {
                        <div class="invalid-feedback">ФИО обязательно</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label text-white">Телефон <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text input-group-text-dark">+7</span>
                        <input type="tel" class="form-control form-control-dark @(regPhoneError ? "is-invalid" : "")"
                               @bind="_regPhone" @bind:event="oninput" placeholder="9991234567" maxlength="10" />
                    </div>
                    @if (regPhoneError)
                    {
                        <div class="invalid-feedback">Введите корректный номер телефона</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label text-white">Email</label>
                    <input type="email" class="form-control form-control-dark @(regEmailError ? "is-invalid" : "")"
                           @bind="_regEmail" @bind:event="oninput" placeholder="example@mail.com" />
                    @if (regEmailError)
                    {
                        <div class="invalid-feedback">Введите корректный email</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label text-white">Пароль <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="@(showRegPassword ? "text" : "password")"
                               class="form-control form-control-dark @(regPasswordError ? "is-invalid" : "")"
                               @bind="_regPassword" @bind:event="oninput" placeholder="Минимум 6 символов" />
                        <button class="btn btn-outline-teal" type="button" @onclick="() => showRegPassword = !showRegPassword">
                            <i class="fas @(showRegPassword ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                    @if (regPasswordError)
                    {
                        <div class="invalid-feedback">Пароль должен быть не менее 6 символов</div>
                    }
                </div>

                <div class="alert alert-info small">
                    <i class="fas fa-info-circle me-1 text-teal"></i>
                    После регистрации вы сможете записываться к мастерам
                </div>

                <button class="btn btn-teal w-100 py-2" @onclick="Register" disabled="@isRegistering">
                    @if (isRegistering)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="fas fa-check me-2"></i>Зарегистрироваться
                </button>

                <div class="text-center mt-3">
                    <p class="text-white-50 mb-0">
                        Уже есть аккаунт?
                        <button class="btn btn-link p-0 text-teal" @onclick="SwitchToLogin">
                            Войти
                        </button>
                    </p>
                </div>
            </div>
        </div>
    }
</div>

<style>
