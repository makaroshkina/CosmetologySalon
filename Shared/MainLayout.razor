        margin-top: 0.25rem;
        display: block;
    }

    .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #f87171;
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
    }

    .alert-info {
        background: rgba(20, 184, 166, 0.1);
        border: 1px solid rgba(20, 184, 166, 0.2);
        color: #14b8a6;
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
    }

    .text-teal {
        color: #14b8a6 !important;
    }

    .text-white-50 {
        color: rgba(255,255,255,0.5) !important;
    }

    .w-100 {
        width: 100%;
    }

    .text-center {
        text-align: center;
    }

    .mt-3 {
        margin-top: 1rem;
    }

    .mb-0 {
        margin-bottom: 0;
    }

    .me-1 {
        margin-right: 0.25rem;
    }

    .me-2 {
        margin-right: 0.5rem;
    }

    .ms-2 {
        margin-left: 0.5rem;
    }

    .py-2 {
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
    }

    .small {
        font-size: 0.75rem;
    }

    .spinner-border-sm {
        width: 1rem;
        height: 1rem;
        border-width: 0.2em;
    }

    .d-flex {
        display: flex;
    }

    .gap-2 {
        gap: 0.5rem;
    }

    .align-items-center {
        align-items: center;
    }

    .justify-content-between {
        justify-content: space-between;
    }

    .flex-column {
        flex-direction: column;
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .nav-menu

    {
        display: none;
    }

    .main-content {
        margin-left: 0;
        width: 100%;
    }

    .top-bar-content {
        padding: 0 1rem;
    }

    .brand-logo span {
        display: none;
    }

    }
</style>

@code {
    private int _currentClientId = 0;
    private string _currentClientName = string.Empty;
    private bool showDropdown = false;

    private bool showLoginModal = false;
    private bool isLoggingIn = false;
    private string loginErrorMessage = string.Empty;
    private string _loginPhone = string.Empty;
    private string _loginPassword = string.Empty;
    private bool showLoginPassword = false;
    private bool loginPhoneError = false;
    private bool loginPasswordError = false;

    private bool showRegisterModal = false;
    private bool isRegistering = false;
    private string registerErrorMessage = string.Empty;
    private string _regFullName = string.Empty;
    private string _regPhone = string.Empty;
    private string? _regEmail = null;
    private string _regPassword = string.Empty;
    private bool showRegPassword = false;
    private bool regNameError = false;
    private bool regPhoneError = false;
    private bool regEmailError = false;
    private bool regPasswordError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentClient();
    }

    private async Task LoadCurrentClient()
    {
        try
        {
            var clientIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "clientId");
            if (!string.IsNullOrEmpty(clientIdStr) && int.TryParse(clientIdStr, out int clientId))
            {
                var client = await Context.Clients.FirstOrDefaultAsync(c => c.ClientId == clientId && c.IsActive);
                if (client != null)
                {
                    _currentClientId = client.ClientId;
                    _currentClientName = client.ClientFullName;
                }
                else
                {
                    await Logout();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        StateHasChanged();
    }

    private void ShowLoginModal()
    {
        _loginPhone = string.Empty;
        _loginPassword = string.Empty;
        loginErrorMessage = string.Empty;
        loginPhoneError = false;
        loginPasswordError = false;
        showLoginModal = true;
        StateHasChanged();
    }

    private void CloseLoginModal()
    {
        showLoginModal = false;
        StateHasChanged();
    }

    private void ShowRegisterModal()
    {
        ResetRegisterForm();
        showRegisterModal = true;
        StateHasChanged();
    }

    private void CloseRegisterModal()
    {
        showRegisterModal = false;
        StateHasChanged();
    }

    private void SwitchToRegister()
    {
        CloseLoginModal();
        ShowRegisterModal();
    }

    private void SwitchToLogin()
    {
        CloseRegisterModal();
        ShowLoginModal();
    }

    private void ResetRegisterForm()
    {
        _regFullName = string.Empty;
        _regPhone = string.Empty;
        _regEmail = null;
        _regPassword = string.Empty;
        registerErrorMessage = string.Empty;
        regNameError = false;
        regPhoneError = false;
        regEmailError = false;
        regPasswordError = false;
    }

    private bool ValidateLogin()
    {
        bool valid = true;
        if (string.IsNullOrWhiteSpace(_loginPhone))
        {
            loginPhoneError = true;
            valid = false;
        }
        else
            loginPhoneError = false;

        if (string.IsNullOrWhiteSpace(_loginPassword))
        {
            loginPasswordError = true;
            valid = false;
        }
        else
            loginPasswordError = false;

        return valid;
    }

    private bool ValidateRegister()
    {
        bool valid = true;
        if (string.IsNullOrWhiteSpace(_regFullName))
        {
            regNameError = true;
            valid = false;
        }
        else
            regNameError = false;

        if (string.IsNullOrWhiteSpace(_regPhone) || _regPhone.Length < 10)
        {
            regPhoneError = true;
            valid = false;
        }
        else
            regPhoneError = false;

        if (!string.IsNullOrWhiteSpace(_regEmail) && !_regEmail.Contains("@"))
        {
            regEmailError = true;
            valid = false;
        }
        else
            regEmailError = false;

        if (string.IsNullOrWhiteSpace(_regPassword) || _regPassword.Length < 6)
        {
            regPasswordError = true;
            valid = false;
        }
        else
            regPasswordError = false;

        return valid;
    }

    private async Task Login()
    {
        if (!ValidateLogin())
        {
            StateHasChanged();
            return;
        }

        isLoggingIn = true;
        loginErrorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var client = await Context.Clients.FirstOrDefaultAsync(c => c.ClientPhone == _loginPhone && c.IsActive);
            if (client == null)
                loginErrorMessage = "Клиент не найден";
            else
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "clientId", client.ClientId.ToString());
                _currentClientId = client.ClientId;
                _currentClientName = client.ClientFullName;
                CloseLoginModal();
                Navigation.NavigateTo("/", true);
            }
        }
        catch (Exception ex)
        {
            loginErrorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoggingIn = false;
            StateHasChanged();
        }
    }

    private async Task Register()
    {
        if (!ValidateRegister())
        {
            StateHasChanged();
            return;
        }

        isRegistering = true;
        registerErrorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var existing = await Context.Clients.FirstOrDefaultAsync(c => c.ClientPhone == _regPhone);
            if (existing != null)
            {
                registerErrorMessage = "Клиент с таким номером уже зарегистрирован";
                return;
            }

            var newClient = new Client
            {
                ClientFullName = _regFullName,
                ClientPhone = _regPhone,
                ClientEmail = string.IsNullOrWhiteSpace(_regEmail) ? null : _regEmail,
                IsActive = true
            };
            Context.Clients.Add(newClient);
            await Context.SaveChangesAsync();

            CloseRegisterModal();
            _loginPhone = _regPhone;
            _loginPassword = string.Empty;
            ShowLoginModal();
        }
        catch (DbUpdateException ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            if (msg.Contains("IX_Clients_ClientPhone"))
                registerErrorMessage = "Номер уже занят";
            else if (msg.Contains("IX_Clients_ClientEmail"))
                registerErrorMessage = "Email уже занят";
            else
                registerErrorMessage = $"Ошибка БД: {msg}";
        }
        catch (Exception ex)
        {
            registerErrorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isRegistering = false;
            StateHasChanged();
        }
    }

    private void ToggleDropdown()
    {
        showDropdown = !showDropdown;
        StateHasChanged();
    }

    private void CloseDropdownOnOutside()
    {
        if (showDropdown)
        {
            showDropdown = false;
            StateHasChanged();
        }
    }

    private void GoToMyAppointments()
    {
        showDropdown = false;
        Navigation.NavigateTo("/appointments");
    }

    private async Task Logout()
    {
        showDropdown = false;
        await JS.InvokeVoidAsync("localStorage.removeItem", "clientId");
        _currentClientId = 0;
        _currentClientName = string.Empty;
        StateHasChanged();
        Navigation.NavigateTo("/", true);
    }
}