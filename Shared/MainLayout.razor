    .brand-logo {
        font-size: 1.25rem;
        font-weight: 600;
        color: #14b8a6;
        cursor: pointer;
        transition: opacity 0.2s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .brand-logo:hover {
