        transition: all 0.2s;
        cursor: pointer;
    }

        .btn-teal:hover {
            background: linear-gradient(135deg, #0f766e 0%, #047857 100%);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 148, 136, 0.4);
        }

        .btn-teal:disabled {
            opacity: 0.6;
            transform: none;
            cursor: not-allowed;
        }

    .btn-outline-teal {
        color: #14b8a6;
        border: 2px solid #14b8a6;
        background: transparent;
        border-radius: 0.75rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        transition: all 0.2s;
