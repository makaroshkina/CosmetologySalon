        }

        .brand-logo i {
            font-size: 1.25rem;
        }

    .auth-buttons {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .content {
        padding-top: 1.5rem;
        padding-bottom: 2rem;
    }

    /* ===== BUTTONS ===== */
    .btn-teal {
        background: linear-gradient(135deg, #0d9488 0%, #059669 100%);
