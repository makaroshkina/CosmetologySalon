    }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 10px 16px;
        text-align: left;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 14px;
        color: #94a3b8;
        transition: all 0.2s ease;
    }

        .dropdown-item:hover {
            background: rgba(20, 184, 166, 0.1);
