    }

    /* ===== DROPDOWN ===== */
    .dropdown-container {
        position: relative;
        display: inline-block;
    }

    .user-menu-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 14px;
        background: linear-gradient(135deg, #0d9488 0%, #059669 100%);
        border: none;
        border-radius: 30px;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 14px;
    }

        .user-menu-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 148, 136, 0.4);
        }

    .dropdown-arrow {
        font-size: 10px;
        margin-left: 5px;
    }

    .dropdown-menu-custom {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 10px;
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        min-width: 220px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        border-radius: 12px;
        border: 1px solid rgba(20, 184, 166, 0.2);
        z-index: 10000;
        overflow: hidden;
    }

    .dropdown-header {
        padding: 12px 16px;
        background: rgba(15, 23, 42, 0.8);
        color: #e2e8f0;
